<idea-plugin>
  <id>com.github.moct10.newdot</id>
  <name>Newdot file Explorer</name>
  <vendor>moct10</vendor>

  <description><![CDATA[
    Adds support for :new . in IdeaVim and opens a file explorer buffer in the editor.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>IdeaVIM</depends>

  <extensions defaultExtensionNs="IdeaVIM">
    <vimExtension implementation="com.github.moct10.newdot.NewDotExtension" name="newdot" />
  </extensions>
</idea-plugin>
